#
# https://help.github.com/articles/dealing-with-line-endings/
#
# Linux start script should use lf
/gradlew        text eol=lf

# These are Windows script files and should use crlf
*.bat           text eol=crlf

# Binary files should be left untouched
*.jar           binary

* text=auto

*.kt      text eol=lf
*.kts     text eol=lf
*.java    text eol=lf
*.gradle  text eol=lf
*.md      text eol=lf